NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
# Wrap values in quotes when they contain #, spaces, or special characters.
MYSQL_PASSWORD=
MYSQL_DATABASE=scmarketplus
MYSQL_CONNECTION_LIMIT=10

MYSQL_UAT_HOST=localhost
MYSQL_UAT_PORT=3306
MYSQL_UAT_USER=zoneUat
MYSQL_UAT_PASSWORD=
MYSQL_UAT_DATABASE=scmarket_uat
MYSQL_UAT_CONNECTION_LIMIT=10

HTTP_TIMEOUT_MS=10000
EXTERNAL_API_BASE_URL=

# Ksher gateway payment
KSHER_GATEWAY_BASE_URL=https://gateway.ksher.com/api
KSHER_PRIVATE_KEY_DIR=./ksher_pay
# KSHER_PRIVATE_KEY_PATH=./ksher_pay/Mch44620_PrivateKey.pem
KSHER_NOTIFY_URL=https://api.scmarketplus.com/CallbackPaymentNotifyURL
KSHER_CHANNEL_LIST=promptpay,truemoney,linepay,card,scb_easy
KSHER_PRODUCT_NAME=จองบูธ SC MARKET
KSHER_LANG=th
KSHER_REFER_URL=http://www.ksher.cn
KSHER_DEVICE=H5
PAYMENT_PUBLIC_BASE_URL=
PAYMENT_TIME_ZONE=Asia/Bangkok

# Firebase Admin options:
# Option 1: point to a service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./sc-market-plus-firebase.json
FIREBASE_PROJECT_ID=sc-market-plus

# Option 2: paste the service account JSON as one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional for Realtime Database. Not required for Firestore or FCM.
FIREBASE_DATABASE_URL=
