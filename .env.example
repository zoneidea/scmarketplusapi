NODE_ENV=development
PORT=3000
CORS_ORIGIN=*

MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
# Wrap values in quotes when they contain #, spaces, or special characters.
MYSQL_PASSWORD=
MYSQL_DATABASE=scmarketplus
MYSQL_CONNECTION_LIMIT=10

HTTP_TIMEOUT_MS=10000
EXTERNAL_API_BASE_URL=

# Firebase Admin options:
# Option 1: point to a service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=./sc-market-plus-firebase.json
FIREBASE_PROJECT_ID=sc-market-plus

# Option 2: paste the service account JSON as one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional for Realtime Database. Not required for Firestore or FCM.
FIREBASE_DATABASE_URL=
